{
  "name": "@flxlfx/cp-stash",
  "version": "0.1.2",
  "description": "CLI to zip git stash and modified files preserving directory structure",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/flxlfx/cp-stash"
  },
  "bin": {
    "cp-stash": "./dist/index.js",
    "cpzip": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target=node --outfile=dist/index.js",
    "dev": "bun run src/index.ts"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "git",
    "stash",
    "zip",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}